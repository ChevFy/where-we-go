@model where_we_go.DTO.PostDetailDto
@using System.Security.Claims

@{
    // Get the ID of the person currently looking at the page
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@{
    ViewData["Title"] = "Post Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/postdetail.css" asp-append-version="true" />

    @* Import component css *@
    <link rel="stylesheet" href="~/css/components/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/mainbutton.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/hamburgermenu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/footer.css" asp-append-version="true" />
}

<header>
    @await Component.InvokeAsync("Navbar")
</header>

<div class="post-bg-container">
    <div class="post-container">
        <img class="post-thumbnail"   src=@Model.PostImgURL    alt="Thumbnail">

        <h2 class="post-title">@Model.Title</h2>

        <div class="post-location">
            <a href="https://www.google.com/maps/search/?api=1&query=@Model.Locationlat,@Model.Locationlon">
                @Model.LocationName 
            </a>
        </div>

        <div class="post-date">
            <p>📅 @Model.DateDeadlineFormatted</p>
        </div>

        <div class="post-population">
            <p>👥 @Model.CurrentParticipants / @Model.MaxParticipants People</p>
        </div>

        <div class="post-category">
            <ul>
                @if (Model.Categories.Count > 0)
                {
                    @foreach (var category in Model.Categories)
                    {
                        <li>@category.Name</li>
                    }
                }
                else
                {
                    <li>Uncategorized</li>
                }
            </ul>
        </div>

        <div class="post-description">
            <p>@Model.Description</p>
        </div>
        <div class="join-section">
            @* Check if user is logged in AND not the owner of the post *@
            @if (User.Identity?.IsAuthenticated == true && currentUserId != Model.UserId)
            {
                @if (Model.IsJoined)
                {
                    <form asp-action="LeavePost" asp-controller="Post" asp-route-id="@Model.PostId" method="post">
                        <button type="submit" class="btn" style="background-color: rgb(243, 49, 49);">Leave Activity</button>
                    </form>
                }
                else
                {
                    <form asp-action="JoinPost" asp-controller="Post" asp-route-id="@Model.PostId" method="post">
                        <button type="submit" class="btn" style="background-color: rgb(96, 241, 28);">Join Activity</button>
                    </form>
                }
            }
        </div>
        @* Only show delete if user is logged in AND they are the creator *@
        @if (User.Identity?.IsAuthenticated == true && currentUserId == Model.UserId)
        {
            <form asp-action="PostDelete" asp-controller="Post" asp-route-id="@Model.PostId" method="post"
                  onsubmit="return confirm('Do you really want to delete this post?');">
                <button type="submit" class="btn btn-danger">Delete This Post</button>
            </form>
        }
    </div>
</div>
@if (TempData["AlertMessage"] != null)
{
    <script type="text/javascript">
        alert('@TempData["AlertMessage"]');
    </script>
}
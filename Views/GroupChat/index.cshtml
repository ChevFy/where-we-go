@{
    ViewData["Title"] = "Group Chat";

    // ===== Mock GROUPCHAT =====
    var groupChat = new
    {
        GroupChatId = Guid.Parse("11111111-1111-1111-1111-111111111111"),
        Name = "Meeting name",
        CreatedAt = DateTime.UtcNow
    };

    // mock current user
    var currentUserId = Guid.Parse("aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa");

    // ===== Mock CHATMESSAGE =====
    var messages = new[]
    {
        new {
            MessageId = Guid.NewGuid(),
            GroupChatId = groupChat.GroupChatId,
            UserId = Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"),
            UserName = "NanthaPong",
            Message = "Hello! Have you seen my backpack anywhere in office?",
            SentAt = "15:42"
        },
        new {
            MessageId = Guid.NewGuid(),
            GroupChatId = groupChat.GroupChatId,
            UserId = currentUserId,
            UserName = "Me",
            Message = "Hi, yes, David have found it, ask our concierge 👀",
            SentAt = "15:42"
        }
    };
}
<link rel="stylesheet" href="~/css/GroupChat.css" />

<div class="chat-page">

    <!-- HEADER -->
    <div class="chat-header">
        <h3>@groupChat.Name</h3>
        <small>Created @groupChat.CreatedAt.ToShortDateString()</small>
    </div>

    <!-- MESSAGE LIST -->
    <div class="chat-messages">
        @foreach (var msg in messages)
        {
            bool isMe = msg.UserId == currentUserId;

            <div class="message-row @(isMe ? "me" : "other")">
                <div class="message-bubble">
                    @if (!isMe)
                    {
                        <div class="sender">@msg.UserName</div>
                    }
                    <div class="text">@msg.Message</div>
                    <div class="time">@msg.SentAt</div>
                </div>
            </div>
        }
    </div>

    <!-- INPUT -->
    <div class="chat-input">
        <input type="text" placeholder="Type your message here..." />
        <button>Send</button>
    </div>

</div>  
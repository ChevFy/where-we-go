@model where_we_go.DTO.UserResponseDto
@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/userprofile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/userposts.css" asp-append-version="true" />

    @* Import component css *@
    <link rel="stylesheet" href="~/css/components/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/mainbutton.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/hamburgermenu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/footer.css" asp-append-version="true" />
}

<header>
    @await Component.InvokeAsync("Navbar")
</header>

<div class="profile-layout">
    @await Html.PartialAsync("_UserProfileSidebar", Model)

    <div class="profile-main-content">
        <div class="profile-card">
            <div class="profile-top">
                <img src=@Model.ProfileUrl>
                <div class="profile-top-content">
                    <p style="color: var(--option-color); font-size: var(--font-size-medium);">@Model.Name</p>
                    <p>@Model.Bio</p>
                </div>
            </div>
            <hr style="border: 0; border-top: 2px solid rgba(0,0,0,0.4); margin: 20px auto; width: 75%;" />
            <div class="profile-below">
                <div class="profile-info-group">
                    <div class="info-row">
                        <div class="info-label">
                            <span>👤 Username</span>
                        </div>
                        <div class="info-value">@Model.UserName</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">
                            <span>✉️ Email</span>
                        </div>
                        <div class="info-value">@Model.Email</div>
                    </div>
                </div>
            </div>

            <div class="profile-actions">
                @if (ViewBag.isOwner)
                {
                    <div class="profile-button">
                        <a asp-controller="User" asp-action="UserEdit" class="edit-wrapper">
                            @await Component.InvokeAsync("MainButton", new
                            {
                                targetId = "Edit",
                                buttonType = "submit",
                                width = "100%",
                                text = "แก้ไขข้อมูล",
                            })
                        </a>
                        <a asp-controller="auth" asp-action="logout" class="logout-wrapper">
                            @await Component.InvokeAsync("MainButton", new
                            {
                                targetId = "Logout",
                                imageUrl = "/images/logout.svg",
                                buttonType = "submit",
                                width = "100%",
                                text = "ออกจากระบบ",
                                color = "#fef2f2",
                                hoverColor = "#fee2e2",
                                textColor = "#ef4444"
                            })
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<footer>
    @await Component.InvokeAsync("Footer")
</footer>